# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Paste these into Coolify → Service → Environment Variables.
# NEVER commit the actual .env file.
# ─────────────────────────────────────────────────────────────────────────────
#
# COOLIFY DOMAIN SETUP (do this in Coolify UI → General → Domains):
#   • "Domains for jdgk-website" → https://jdgkbsi.ph
#   • "Domains for backend"      → LEAVE EMPTY (nginx proxies /api internally)
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (REQUIRED) ─────────────────────────────────────────────────────
# Point this at your Coolify-managed or external PostgreSQL instance.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:CHANGE_ME@your-db-host:5432/jdgk_cms

# ── Backend Auth (REQUIRED) ──────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_A_64_CHAR_HEX_STRING_HERE

# Default admin credentials (created on first boot)
# REQUIRED — server will refuse to start without this. Use a strong password.
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# JWT token lifetime in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS (REQUIRED for production) ──────────────────────────────────────────
# Comma-separated origins — must match your live domain(s)
ALLOWED_ORIGINS=https://jdgkbsi.ph,https://www.jdgkbsi.ph

# ── Frontend (build-time arg) ────────────────────────────────────────────────
# Keep as /api — Nginx proxies /api/* to the backend container
VITE_API_URL=/api

# ── Mail / SMTP (optional — contact form won't send email without this) ──────
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=info@jdgkbsi.ph
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
